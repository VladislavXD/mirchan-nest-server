# ===================================
# 🚀 PRODUCTION CONFIGURATION EXAMPLE
# ===================================
# Скопируйте этот файл в .env и обновите значения для продакшена

# ============
# APPLICATION
# ============
NODE_ENV='production'
VERCEL=true
APPLICATION_PORT=4000
APPLICATION_URL='https://mirchan-expres-api.onrender.com'

# ===========================
# CORS - MULTIPLE ORIGINS
# ===========================
# ⚠️ ВАЖНО: Перечислите ВСЕ домены через запятую!
# Включите основной домен, www-версию и все субдомены
ALLOWED_ORIGIN='https://mirchan.site,https://www.mirchan.site,https://mirchan.vercel.app'

# ============
# SESSIONS
# ============
SESSION_SECRET='ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_32+_СИМВОЛОВ'
SESSION_NAME='mirchan_session'
SESSION_DOMAIN='.mirchan.site'  # Точка в начале для поддержки субдоменов (www, api, socket)
SESSION_MAX_AGE='30d'
SESSION_HTTP_ONLY=true
SESSION_SECURE=true  # ⚠️ ОБЯЗАТЕЛЬНО true для HTTPS!
SESSION_SAME_SITE='none'  # 'none' для cross-site cookies (требует HTTPS + secure=true)
SESSION_FOLDER='sessions:'

# ============
# COOKIES
# ============
COOKIES_SECRET='ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ'

# ============
# AUTH
# ============
NEXTAUTH_SECRET='ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_NEXTAUTH'

# ============
# DATABASE
# ============
# MongoDB Atlas или другая продакшн БД
DATABASE_URL='mongodb+srv://username:password@cluster.mongodb.net/mirchan?retryWrites=true&w=majority'

# ============
# REDIS
# ============
# Redis Cloud или Upstash
REDIS_URI='redis://default:password@redis-12345.upstash.io:6379'

# ============
# CLOUDINARY
# ============
CLOUDINARY_CLOUD_NAME='your_cloud_name'
CLOUDINARY_API_KEY='your_api_key'
CLOUDINARY_API_SECRET='your_api_secret'

# ============
# EMAIL (Resend)
# ============
RESEND_API_KEY='re_xxxxxxxxxxxxxxxxxxxxx'

# ============
# JWT
# ============
JWT_ACCESS_SECRET='ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_JWT_ACCESS'
JWT_REFRESH_SECRET='ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_JWT_REFRESH'
JWT_ACCESS_EXPIRES_IN='15m'
JWT_REFRESH_EXPIRES_IN='7d'

# ============
# RATE LIMITING
# ============
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============
# DEPLOYMENT
# ============
# Для Render.com/Railway/Vercel:
# 1. Добавьте все переменные в панель управления
# 2. Убедитесь, что SESSION_SECURE=true
# 3. Добавьте ВСЕ домены в ALLOWED_ORIGIN
# 4. Установите SESSION_SAME_SITE='none' для cross-origin cookies
